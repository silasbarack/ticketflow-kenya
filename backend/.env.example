# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ticketflow_kenya?schema=public"

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# M-Pesa Daraja (Safaricom) sandbox credentials
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_daraja_passkey
MPESA_CALLBACK_URL=https://your-public-domain.com/payments/mpesa/callback
MPESA_ENV=sandbox

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000

# Server
PORT=4000

# Platform commission (percentage, default 7 = 7%)
PLATFORM_COMMISSION_PERCENT=7

# Enable development-only mock payment endpoint (never enable in production)
ENABLE_MOCK_PAYMENTS=true

# Ticket QR code signing secret (generate with: openssl rand -hex 32)
TICKET_QR_SECRET=replace_with_a_long_random_secret

# Public URL of this API (used in ticket PDF links)
APP_URL=https://your-api-domain.onrender.com

# SMTP email delivery (leave blank to disable email — tickets still generate normally)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="TicketFlow Kenya <tickets@ticketflow.co.ke>"
